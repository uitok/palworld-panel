# Runtime data
/data/
/dev-runtime/
/dist/
/.playwright-cli/
/output/
/*.log

# Defensive SteamCMD credential/session and download exclusions. The managed runtime
# should already be below dev-runtime, but these prevent accidental alternate-root adds.
**/steamcmd/config/
**/steamcmd/userdata/
**/steamcmd/logs/
**/steamcmd/steamapps/
**/steamcmd/steamcmd.exe
**/steamcmd/steamclient.dll

# Backend build and local logs
/backend/bin/
/backend/*.log

# Frontend dependencies and build output
/frontend/node_modules/
/frontend/dist/
/frontend/.playwright-cli/
/frontend/output/
/frontend/playwright-report/
/frontend/test-results/

# Generated Python and .NET build output
**/__pycache__/
*.py[cod]
/palcalc-bridge/bin/
/palcalc-bridge/obj/

# Local design reference used while rebuilding the client
/PalPanel-Frontend-Preview.zip

# Local environment overrides
*.local
.env
.env.*.local
/.palpanel-restconfig-*.json

# OS/editor files
.DS_Store
Thumbs.db
.idea/
.vscode/
