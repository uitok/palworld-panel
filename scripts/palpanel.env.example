PALPANEL_REQUIRE_AUTH=true
PALPANEL_LISTEN_ADDR=127.0.0.1:8080
PALPANEL_CORS_ORIGINS=
PALPANEL_MAX_UPLOAD_MB=256

# scripts/start.* set these to package-local paths by default:
# PALPANEL_BACKEND_DIR=<package>/backend
# PALPANEL_DATA_DIR=<package>/data
# PALPANEL_RUNNER_DIR=<package>/backend/deployments/wine-runner

PALPANEL_DOCKER_RUNNER_BASE_IMAGE=scottyhardy/docker-wine:latest@sha256:477aae36af41923cfb5eefb23923b035f8010caa49eaded952316f937dd8a49b
PALPANEL_DOCKER_RUNNER_BASE_IMAGE_MIRRORS=docker.m.daocloud.io,docker.1ms.run,registry.cyou,dockerproxy.net,dockerproxy.link,docker.jiaxin.site,docker.xuanyuan.me,free.hubfast.cn
PALPANEL_WORKSHOP_APP_ID=1623730
# Optional runtime override for the bundled, obfuscated Workshop search key.
STEAM_WEB_API_KEY=
PALPANEL_STEAM_API_BASE_URL=https://api.steampowered.com
PALPANEL_STEAM_API_TIMEOUT_SECONDS=15

# 可发现社区服务器。浏览器和 AstrBot 只访问 PalPanel，由后端缓存并代理查询。
PALPANEL_COMMUNITY_SERVERS_ENABLED=true
PALPANEL_COMMUNITY_SERVERS_API_BASE_URL=https://api.battlemetrics.com
# 国内网络无法直连时可单独配置，不影响其他下载器。
# PALPANEL_COMMUNITY_SERVERS_PROXY_URL=socks5h://127.0.0.1:10808
PALPANEL_COMMUNITY_SERVERS_CACHE_TTL_SECONDS=60
PALPANEL_COMMUNITY_SERVERS_STALE_TTL_SECONDS=86400
PALPANEL_COMMUNITY_SERVERS_RATE_LIMIT=30

PALPANEL_GAME_PORT=8211
PALPANEL_QUERY_PORT=27015
PALPANEL_RCON_HOST=127.0.0.1
PALPANEL_RCON_PORT=25575
PALPANEL_REST_PORT=8212
PALWORLD_REST_BASE_URL=http://127.0.0.1:8212/v1/api
PALWORLD_REST_USER=admin
# Production `palpanelctl init` generates this value automatically. Keep it secret.
PALWORLD_ADMIN_PASSWORD=
PALPANEL_PALWORLD_REST_READ_TIMEOUT_MS=1200
PALPANEL_GAME_DATA_TIMEOUT_MS=3000
PALPANEL_GAME_DATA_MAX_MB=16

PALPANEL_PALDEFENDER_REST_PORT=17993
PALPANEL_PALDEFENDER_REST_BASE_URL=http://127.0.0.1:17993

PALPANEL_SAVE_INDEXER_ENABLED=true
PALPANEL_SAVE_INDEXER_URL=http://127.0.0.1:8090
PALPANEL_PALCALC_URL=http://127.0.0.1:8091
PALPANEL_PALCALC_TIMEOUT_SECONDS=300

# AstrBot integration. Generate a long random value and configure the same
# secret in astrbot_plugin_palpanel. Keep the plugin on loopback unless HTTPS
# is configured between the two services.
PALPANEL_ASTRBOT_PLUGIN_URL=http://127.0.0.1:8092
PALPANEL_ASTRBOT_PANEL_ID=palpanel
PALPANEL_ASTRBOT_SHARED_SECRET=
PALPANEL_SAVE_INDEX_TIMEOUT_SECONDS=120

PALPANEL_PERF_SLOW_REQUEST_MS=500
PALPANEL_MONITOR_RETENTION_DAYS=7
PALPANEL_AI_TRANSLATION_TIMEOUT_SECONDS=90
PALPANEL_LOG_LEVEL=info

# Docker/Wine Workshop login. Both values are required on Linux, are read only from this
# mode-0600 environment file, and are passed to Docker without embedding the password in
# command arguments. Native Windows Workshop login does not read these values: enter only
# the account name in PalPanel, then complete password and Steam Guard prompts in the
# separate local SteamCMD console.
STEAM_USERNAME=
STEAM_PASSWORD=

# Optional proxy settings. Uncomment only when the host needs proxy access.
# HTTP_PROXY=socks5://127.0.0.1:10808
# HTTPS_PROXY=socks5://127.0.0.1:10808
# ALL_PROXY=socks5://127.0.0.1:10808
