#!/usr/bin/env bash
set -euo pipefail
umask 077

script_path="$(readlink -f -- "${BASH_SOURCE[0]}")"
script_dir="$(cd -- "$(dirname -- "$script_path")" && pwd -P)"
if [[ -d "$script_dir/bin" ]]; then
  package_dir="$script_dir"
else
  package_dir="$(cd -- "$script_dir/.." && pwd -P)"
fi
ctl="$script_path"
backend_bin="$package_dir/bin/palpanel"
sav_bin="$package_dir/bin/sav-cli"
palcalc_bin="$package_dir/bin/palcalc-bridge"

opt_root="${PALPANEL_INSTALL_ROOT:-/opt/palpanel}"
etc_dir="${PALPANEL_ETC_DIR:-/etc/palpanel}"
system_data_dir="${PALPANEL_SYSTEM_DATA_DIR:-/var/lib/palpanel}"
systemd_dir="${PALPANEL_SYSTEMD_DIR:-/etc/systemd/system}"
bin_link="${PALPANEL_BIN_LINK:-/usr/local/bin/palpanelctl}"
service_user="${PALPANEL_SERVICE_USER:-palpanel}"
test_mode="${PALPANEL_TEST_MODE:-0}"

portable_config="${PALPANEL_CONFIG:-$package_dir/config/palpanel.env}"
portable_data="${PALPANEL_DATA_DIR:-$package_dir/data}"
runtime_dir="${PALPANEL_RUNTIME_DIR:-$package_dir/run}"
log_dir="${PALPANEL_LOG_DIR:-$package_dir/logs}"
sidecar_port="${PALPANEL_SAVE_INDEXER_PORT:-8090}"
palcalc_port="${PALPANEL_PALCALC_PORT:-8091}"
max_log_bytes="${PALPANEL_MAX_LOG_BYTES:-10485760}"
max_log_files="${PALPANEL_MAX_LOG_FILES:-5}"

fail() {
  printf 'palpanelctl: %s\n' "$*" >&2
  exit 1
}

require_binary() {
  [[ -x "$1" ]] || fail "missing executable: $1"
}

system_mode() {
  [[ "$package_dir" == "$opt_root/"* ]]
}

config_path() {
  if system_mode; then
    printf '%s\n' "$etc_dir/palpanel.env"
  else
    printf '%s\n' "$portable_config"
  fi
}

read_config_value() {
  local name="$1"
  local path="$2"
  [[ -f "$path" ]] || return 0
  awk -v wanted="$name" '
    /^[[:space:]]*#/ || /^[[:space:]]*$/ { next }
    {
      equals = index($0, "=")
      if (equals == 0) next
      key = substr($0, 1, equals - 1)
      gsub(/^[[:space:]]+|[[:space:]]+$/, "", key)
      if (key != wanted) next
      value = substr($0, equals + 1)
      gsub(/^[[:space:]]+|[[:space:]]+$/, "", value)
      if (length(value) >= 2) {
        first = substr(value, 1, 1)
        last = substr(value, length(value), 1)
        if ((first == "\"" && last == "\"") || (first == "\047" && last == "\047")) {
          value = substr(value, 2, length(value) - 2)
        }
      }
      print value
      exit
    }
  ' "$path"
}

portable_init() {
  require_binary "$backend_bin"
  mkdir -p "$(dirname -- "$portable_config")" "$portable_data" "$runtime_dir" "$log_dir"
  "$backend_bin" --config "$portable_config" --init-config
  chmod 600 "$portable_config"
}

ensure_portable_config() {
  if [[ ! -f "$portable_config" ]]; then
    portable_init
  else
    chmod 600 "$portable_config"
  fi
}

pid_running() {
  local path="$1"
  local pid
  [[ -f "$path" ]] || return 1
  pid="$(tr -cd '0-9' <"$path")"
  [[ -n "$pid" ]] && kill -0 "$pid" 2>/dev/null
}

stop_pid_file() {
  local path="$1"
  local pid=""
  [[ -f "$path" ]] || return 0
  pid="$(tr -cd '0-9' <"$path")"
  if [[ -n "$pid" ]] && kill -0 "$pid" 2>/dev/null; then
    kill -TERM "$pid" 2>/dev/null || true
    for _ in $(seq 1 150); do
      kill -0 "$pid" 2>/dev/null || break
      sleep 0.1
    done
    if kill -0 "$pid" 2>/dev/null; then
      kill -KILL "$pid" 2>/dev/null || true
    fi
  fi
  rm -f "$path"
}

rotate_log() {
  local path="$1"
  local size=0
  [[ -f "$path" ]] || return 0
  size="$(stat -c '%s' "$path" 2>/dev/null || printf '0')"
  (( size >= max_log_bytes )) || return 0
  local index
  for ((index = max_log_files; index >= 2; index--)); do
    if [[ -f "$path.$((index - 1))" ]]; then
      mv -f "$path.$((index - 1))" "$path.$index"
    fi
  done
  cp "$path" "$path.1"
  : >"$path"
}

http_ready() {
  local url="$1"
  if command -v curl >/dev/null 2>&1; then
    curl --fail --silent --show-error --max-time 2 "$url" >/dev/null 2>&1
  elif command -v wget >/dev/null 2>&1; then
    wget -q -T 2 -O /dev/null "$url"
  else
    fail "curl or wget is required for health checks"
  fi
}

wait_for_health() {
  local url="$1"
  local pid_file="$2"
  local attempts="${3:-60}"
  local stable_attempts=5
  local attempt
  local healthy_attempts=0
  for ((attempt = 1; attempt <= attempts; attempt++)); do
    pid_running "$pid_file" || return 1
    if http_ready "$url"; then
      pid_running "$pid_file" || return 1
      healthy_attempts=$((healthy_attempts + 1))
      if (( healthy_attempts >= stable_attempts )); then
        return 0
      fi
    else
      healthy_attempts=0
    fi
    sleep 0.5
  done
  return 1
}

require_unused_health_endpoint() {
  local name="$1"
  local url="$2"
  if http_ready "$url"; then
    printf '%s health endpoint is already responding before startup: %s\n' "$name" "$url" >&2
    return 1
  fi
}

backend_health_url() {
  local listen="${PALPANEL_LISTEN_ADDR:-}"
  if [[ -z "$listen" ]]; then
    listen="$(read_config_value PALPANEL_LISTEN_ADDR "$portable_config")"
  fi
  [[ -n "$listen" ]] || listen="127.0.0.1:8080"
  local port="${listen##*:}"
  port="${port//]/}"
  [[ "$port" =~ ^[0-9]+$ ]] || port="8080"
  printf 'http://127.0.0.1:%s/api/health\n' "$port"
}

supervisor_cleanup() {
  stop_pid_file "$runtime_dir/backend.pid"
  stop_pid_file "$runtime_dir/sav-cli.pid"
  stop_pid_file "$runtime_dir/palcalc-bridge.pid"
  rm -f "$runtime_dir/ready" "$runtime_dir/supervisor.pid"
}

supervise() {
  require_binary "$backend_bin"
  require_binary "$sav_bin"
  require_binary "$palcalc_bin"
  ensure_portable_config
  mkdir -p "$portable_data" "$runtime_dir" "$log_dir"
  if pid_running "$runtime_dir/supervisor.pid"; then
    fail "portable instance is already running"
  fi
  local sav_health_url="http://127.0.0.1:$sidecar_port/health"
  local panel_health_url
  local palcalc_health_url="http://127.0.0.1:$palcalc_port/health"
  panel_health_url="$(backend_health_url)"
  require_unused_health_endpoint "sav-cli" "$sav_health_url" || return 1
  require_unused_health_endpoint "palcalc-bridge" "$palcalc_health_url" || return 1
  require_unused_health_endpoint "palpanel" "$panel_health_url" || return 1
  printf '%s\n' "$BASHPID" >"$runtime_dir/supervisor.pid"
  rm -f "$runtime_dir/ready"
  trap 'exit 0' INT TERM HUP
  trap supervisor_cleanup EXIT

  rotate_log "$log_dir/sav-cli.log"
  "$sav_bin" serve --host 127.0.0.1 --port "$sidecar_port" >>"$log_dir/sav-cli.log" 2>&1 &
  printf '%s\n' "$!" >"$runtime_dir/sav-cli.pid"
  if ! wait_for_health "$sav_health_url" "$runtime_dir/sav-cli.pid"; then
    printf 'sav-cli failed its health check\n' >&2
    return 1
  fi

  rotate_log "$log_dir/palcalc-bridge.log"
  PALCALC_BRIDGE_URLS="http://127.0.0.1:$palcalc_port" PALCALC_BRIDGE_CONCURRENCY=1 \
    "$palcalc_bin" >>"$log_dir/palcalc-bridge.log" 2>&1 &
  printf '%s\n' "$!" >"$runtime_dir/palcalc-bridge.pid"
  if ! wait_for_health "$palcalc_health_url" "$runtime_dir/palcalc-bridge.pid" 90; then
    printf 'palcalc-bridge failed its health check\n' >&2
    return 1
  fi

  rotate_log "$log_dir/palpanel.log"
  PALPANEL_BACKEND_DIR="$package_dir/backend" \
  PALPANEL_DATA_DIR="$portable_data" \
  PALPANEL_RUNNER_DIR="$package_dir/backend/deployments/wine-runner" \
  PALPANEL_SAVE_INDEXER_ENABLED=true \
  PALPANEL_SAVE_INDEXER_URL="http://127.0.0.1:$sidecar_port" \
  PALPANEL_PALCALC_URL="http://127.0.0.1:$palcalc_port" \
    "$backend_bin" --config "$portable_config" >>"$log_dir/palpanel.log" 2>&1 &
  printf '%s\n' "$!" >"$runtime_dir/backend.pid"
  if ! wait_for_health "$panel_health_url" "$runtime_dir/backend.pid"; then
    printf 'palpanel failed its health check\n' >&2
    return 1
  fi
  : >"$runtime_dir/ready"

  while pid_running "$runtime_dir/backend.pid" && pid_running "$runtime_dir/sav-cli.pid" && pid_running "$runtime_dir/palcalc-bridge.pid"; do
    rotate_log "$log_dir/palpanel.log"
    rotate_log "$log_dir/sav-cli.log"
    rotate_log "$log_dir/palcalc-bridge.log"
    sleep 2
  done
  printf 'a managed process exited unexpectedly\n' >&2
  return 1
}

portable_start() {
  ensure_portable_config
  mkdir -p "$runtime_dir" "$log_dir"
  if pid_running "$runtime_dir/supervisor.pid"; then
    printf 'PalPanel is already running\n'
    return 0
  fi
  rm -f "$runtime_dir/ready"
  rotate_log "$log_dir/controller.log"
  nohup "$ctl" __supervise >>"$log_dir/controller.log" 2>&1 &
  local supervisor_pid="$!"
  for _ in $(seq 1 80); do
    if [[ -f "$runtime_dir/ready" ]]; then
      if kill -0 "$supervisor_pid" 2>/dev/null &&
        pid_running "$runtime_dir/backend.pid" &&
        pid_running "$runtime_dir/sav-cli.pid" &&
        pid_running "$runtime_dir/palcalc-bridge.pid"; then
        printf 'PalPanel started: %s\n' "$(backend_health_url | sed 's|/api/health$|/|')"
        return 0
      fi
    fi
    if ! kill -0 "$supervisor_pid" 2>/dev/null; then
      tail -n 40 "$log_dir/controller.log" >&2 || true
      fail "portable startup failed"
    fi
    sleep 0.5
  done
  kill -TERM "$supervisor_pid" 2>/dev/null || true
  fail "portable startup timed out"
}

portable_stop() {
  if pid_running "$runtime_dir/supervisor.pid"; then
    stop_pid_file "$runtime_dir/supervisor.pid"
  fi
  stop_pid_file "$runtime_dir/backend.pid"
  stop_pid_file "$runtime_dir/sav-cli.pid"
  stop_pid_file "$runtime_dir/palcalc-bridge.pid"
  rm -f "$runtime_dir/ready"
  printf 'PalPanel stopped\n'
}

portable_status() {
  local backend_state="stopped"
  local sav_state="stopped"
  local palcalc_state="stopped"
  pid_running "$runtime_dir/backend.pid" && backend_state="running"
  pid_running "$runtime_dir/sav-cli.pid" && sav_state="running"
  pid_running "$runtime_dir/palcalc-bridge.pid" && palcalc_state="running"
  printf 'palpanel: %s\nsav-cli: %s\npalcalc-bridge: %s\n' "$backend_state" "$sav_state" "$palcalc_state"
  [[ "$backend_state" == "running" && "$sav_state" == "running" && "$palcalc_state" == "running" ]]
}

show_logs() {
  local follow=0
  [[ "${1:-}" == "-f" || "${1:-}" == "--follow" ]] && follow=1
  if system_mode; then
    if (( follow )); then
      exec journalctl -u palpanel.service -u palpanel-sav-cli.service -u palpanel-palcalc.service -f
    fi
    exec journalctl -u palpanel.service -u palpanel-sav-cli.service -u palpanel-palcalc.service -n 200 --no-pager
  fi
  mkdir -p "$log_dir"
  touch "$log_dir/palpanel.log" "$log_dir/sav-cli.log" "$log_dir/palcalc-bridge.log" "$log_dir/controller.log"
  if (( follow )); then
    exec tail -n 100 -F "$log_dir/palpanel.log" "$log_dir/sav-cli.log" "$log_dir/palcalc-bridge.log" "$log_dir/controller.log"
  fi
  tail -n 100 "$log_dir/palpanel.log" "$log_dir/sav-cli.log" "$log_dir/palcalc-bridge.log" "$log_dir/controller.log"
}

show_config() {
  local path
  path="$(config_path)"
  if [[ "${1:-}" == "edit" ]]; then
    exec "${EDITOR:-vi}" "$path"
  fi
  printf '%s\n' "$path"
}

steam_login() {
  local account_name="${1:-}"
  [[ $# -eq 1 ]] || fail "usage: palpanelctl steam-login STEAM_ACCOUNT"
  [[ "$account_name" =~ ^[A-Za-z0-9_]{3,64}$ ]] || fail "Steam account must contain 3-64 ASCII letters, digits, or underscores"
  command -v docker >/dev/null 2>&1 || fail "docker is required for Linux SteamCMD login"

  local path
  local image
  local data_dir
  local auth_dir
  local owner_uid
  local owner_gid
  local -a proxy_args=()
  path="$(config_path)"
  image="$(read_config_value PALPANEL_DOCKER_IMAGE "$path")"
  [[ -n "$image" ]] || image="palworld-wine-runner:local"
  if system_mode; then
    data_dir="$system_data_dir"
    owner_uid="$(id -u "$service_user")"
    owner_gid="$(id -g "$service_user")"
  else
    data_dir="$portable_data"
    owner_uid="$(id -u)"
    owner_gid="$(id -g)"
  fi
  auth_dir="$data_dir/steamcmd-workshop-config"
  mkdir -p "$auth_dir"
  chmod 700 "$auth_dir"
  if [[ "$(id -u)" -eq 0 ]]; then
    chown "$owner_uid:$owner_gid" "$auth_dir"
  fi

  local proxy_name
  local proxy_value
  for proxy_name in HTTP_PROXY HTTPS_PROXY ALL_PROXY; do
    proxy_value="${!proxy_name:-}"
    [[ -n "$proxy_value" ]] || proxy_value="$(read_config_value "$proxy_name" "$path")"
    if [[ -n "$proxy_value" ]]; then
      proxy_value="${proxy_value//:\/\/127.0.0.1:/:\/\/host.docker.internal:}"
      proxy_value="${proxy_value//:\/\/localhost:/:\/\/host.docker.internal:}"
      printf -v "$proxy_name" '%s' "$proxy_value"
      export "$proxy_name"
      proxy_args+=("-e" "$proxy_name")
    fi
  done

  docker image inspect "$image" >/dev/null 2>&1 || fail "Docker/Wine runner image $image is missing; install or update the server from PalPanel first"
  printf 'SteamCMD will now request the password and Steam Guard code locally. PalPanel will not receive them.\n'
  docker run --rm -it \
    --add-host host.docker.internal:host-gateway \
    -e "PALPANEL_HOST_UID=$owner_uid" \
    -e "PALPANEL_HOST_GID=$owner_gid" \
    -v "$auth_dir:/opt/steamcmd/config" \
    "${proxy_args[@]}" \
    "$image" steam-auth-login "$account_name"
  chmod 700 "$auth_dir"
  if [[ "$(id -u)" -eq 0 ]]; then
    chown -R "$owner_uid:$owner_gid" "$auth_dir"
  fi
  printf 'SteamCMD exited. Return to Mod Management and click Verify login.\n'
}

require_root() {
  [[ "$test_mode" == "1" ]] && return 0
  [[ "$(id -u)" -eq 0 ]] || fail "this command must be run as root"
}

service_control_enabled() {
  [[ "${PALPANEL_SKIP_SYSTEMD:-0}" != "1" ]]
}

validate_listen_addr() {
  local address="$1"
  local host="${address%:*}"
  local port="${address##*:}"
  local port_number
  [[ "$address" =~ ^[^[:space:]#=]+:[0-9]+$ ]] || fail "invalid listen address: $address"
  [[ -n "$host" && "$host" != *'/'* ]] || fail "invalid listen host: $host"
  (( ${#port} <= 5 )) || fail "listen port must be between 1 and 65535"
  port_number=$((10#$port))
  (( port_number >= 1 && port_number <= 65535 )) || fail "listen port must be between 1 and 65535"
}

set_config_value() {
  local name="$1"
  local value="$2"
  local path="$3"
  local temporary="${path}.tmp.$BASHPID"
  awk -v wanted="$name" -v replacement="$name=$value" '
    BEGIN { replaced = 0 }
    {
      equals = index($0, "=")
      key = equals > 0 ? substr($0, 1, equals - 1) : ""
      gsub(/^[[:space:]]+|[[:space:]]+$/, "", key)
      if (key == wanted) {
        if (!replaced) print replacement
        replaced = 1
        next
      }
      print
    }
    END { if (!replaced) print replacement }
  ' "$path" >"$temporary"
  chmod 600 "$temporary"
  mv -f "$temporary" "$path"
}

install_system() {
  require_root
  require_binary "$backend_bin"
  require_binary "$sav_bin"
  local docker_access=0
  local listen_addr=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --docker) docker_access=1 ;;
      --listen)
        [[ $# -ge 2 ]] || fail "--listen requires a host:port value"
        listen_addr="$2"
        shift
        ;;
      --listen=*) listen_addr="${1#*=}" ;;
      *) fail "unknown install option: $1" ;;
    esac
    shift
  done
  if [[ -n "$listen_addr" ]]; then
    validate_listen_addr "$listen_addr"
  fi
  local version
  version="$($backend_bin --version | awk 'NR == 1 { print $2 }')"
  [[ "$version" =~ ^v?[0-9]+\.[0-9]+\.[0-9]+([.-][A-Za-z0-9.-]+)?$ ]] || fail "invalid build version: $version"
  local version_dir="$opt_root/$version"
  local staging="$opt_root/.${version}.tmp.$BASHPID"
  rm -rf "$staging"
  mkdir -p "$staging" "$etc_dir" "$system_data_dir" "$systemd_dir"
  chmod 755 "$opt_root"
  chmod 750 "$etc_dir" "$system_data_dir"
  local item
  for item in bin backend systemd config licenses LICENSE README.md THIRD_PARTY_LICENSES.txt palpanelctl; do
    [[ -e "$package_dir/$item" ]] && cp -a "$package_dir/$item" "$staging/"
  done
  rm -f "$staging/config/palpanel.env"
  rm -rf "$version_dir"
  mv "$staging" "$version_dir"
  chmod 755 "$version_dir"
  rm -f "$opt_root/.current.new"
  ln -s "$version_dir" "$opt_root/.current.new"
  mv -Tf "$opt_root/.current.new" "$opt_root/current"

  if [[ "$test_mode" != "1" ]]; then
    mkdir -p "$(dirname -- "$bin_link")"
    ln -sfn "$opt_root/current/palpanelctl" "$bin_link"
  fi

  if [[ "$test_mode" != "1" ]]; then
    if ! id "$service_user" >/dev/null 2>&1; then
      useradd --system --home-dir "$system_data_dir" --shell /usr/sbin/nologin "$service_user"
    fi
    chown root:root "$opt_root" "$version_dir"
    chown root:"$service_user" "$etc_dir"
    if (( docker_access )); then
      getent group docker >/dev/null || fail "docker group does not exist"
      usermod -aG docker "$service_user"
      printf 'WARNING: docker group membership is effectively root-equivalent.\n' >&2
    fi
  elif (( docker_access )); then
    fail "--docker is not available in test mode"
  fi
  if [[ ! -f "$etc_dir/palpanel.env" ]]; then
    "$version_dir/bin/palpanel" --config "$etc_dir/palpanel.env" --init-config
  fi
  if [[ -n "$listen_addr" ]]; then
    set_config_value PALPANEL_LISTEN_ADDR "$listen_addr" "$etc_dir/palpanel.env"
  fi
  chmod 600 "$etc_dir/palpanel.env"
  if [[ "$test_mode" != "1" ]]; then
    chown "$service_user:$service_user" "$etc_dir/palpanel.env"
    chown -R "$service_user:$service_user" "$system_data_dir"
  fi

  sed -e "s|/opt/palpanel|$opt_root|g" -e "s|/etc/palpanel|$etc_dir|g" -e "s|/var/lib/palpanel|$system_data_dir|g" \
    -e "s|User=palpanel|User=$service_user|g" -e "s|Group=palpanel|Group=$service_user|g" \
    "$version_dir/systemd/palpanel.service" >"$systemd_dir/palpanel.service"
  sed -e "s|/opt/palpanel|$opt_root|g" -e "s|/var/lib/palpanel|$system_data_dir|g" \
    -e "s|User=palpanel|User=$service_user|g" -e "s|Group=palpanel|Group=$service_user|g" \
    "$version_dir/systemd/palpanel-sav-cli.service" >"$systemd_dir/palpanel-sav-cli.service"
  sed -e "s|/opt/palpanel|$opt_root|g" -e "s|/var/lib/palpanel|$system_data_dir|g" \
    -e "s|User=palpanel|User=$service_user|g" -e "s|Group=palpanel|Group=$service_user|g" \
    "$version_dir/systemd/palpanel-palcalc.service" >"$systemd_dir/palpanel-palcalc.service"
  chmod 644 "$systemd_dir/palpanel.service" "$systemd_dir/palpanel-sav-cli.service" "$systemd_dir/palpanel-palcalc.service"
  if service_control_enabled; then
    systemctl daemon-reload
    systemctl enable palpanel-sav-cli.service palpanel-palcalc.service palpanel.service
    systemctl restart palpanel-sav-cli.service palpanel-palcalc.service palpanel.service
  fi
  printf 'installed PalPanel %s in %s\n' "$version" "$version_dir"
}

uninstall_system() {
  require_root
  local purge=0
  [[ "${1:-}" == "--purge" ]] && purge=1 && shift
  [[ $# -eq 0 ]] || fail "unknown uninstall option: $1"
  if service_control_enabled; then
    systemctl disable --now palpanel.service palpanel-sav-cli.service palpanel-palcalc.service 2>/dev/null || true
  fi
  if [[ -L "$bin_link" ]]; then
    local linked_target
    linked_target="$(readlink -f -- "$bin_link" 2>/dev/null || true)"
    if [[ "$linked_target" == "$opt_root/"* ]]; then
      rm -f "$bin_link"
    fi
  fi
  rm -f "$systemd_dir/palpanel.service" "$systemd_dir/palpanel-sav-cli.service" "$systemd_dir/palpanel-palcalc.service"
  if service_control_enabled; then
    systemctl daemon-reload
  fi
  rm -rf "$opt_root"
  if (( purge )); then
    rm -rf "$etc_dir" "$system_data_dir"
    if [[ "$test_mode" != "1" ]]; then
      userdel "$service_user" 2>/dev/null || true
    fi
    printf 'uninstalled PalPanel and purged configuration and data\n'
  else
    printf 'uninstalled PalPanel; preserved %s and %s\n' "$etc_dir" "$system_data_dir"
  fi
}

usage() {
  cat <<'EOF'
Usage: palpanelctl COMMAND [OPTIONS]

Commands:
  init                 create a secure portable configuration
  run                  run portable PalPanel in the foreground
  start                start both managed processes
  stop                 stop both managed processes
  restart              restart both managed processes
  status               show process or systemd status
  logs [-f]            show or follow bounded logs
  config [edit]        print or edit the active config path
  steam-login ACCOUNT  securely create/refresh the Linux SteamCMD login cache
  install [--docker] [--listen HOST:PORT]
                       install under /opt and enable systemd services
  uninstall [--purge]  remove programs; preserve config/data unless purged
EOF
}

command="${1:-}"
[[ $# -gt 0 ]] && shift
case "$command" in
  __supervise) supervise "$@" ;;
  init)
    if system_mode; then
      "$backend_bin" --config "$etc_dir/palpanel.env" --init-config
    else
      portable_init
    fi
    ;;
  run)
    if system_mode; then
      systemctl start palpanel-sav-cli.service palpanel-palcalc.service palpanel.service
      exec journalctl -u palpanel.service -u palpanel-sav-cli.service -u palpanel-palcalc.service -f
    fi
    supervise
    ;;
  start)
    if system_mode; then systemctl start palpanel-sav-cli.service palpanel-palcalc.service palpanel.service; else portable_start; fi
    ;;
  stop)
    if system_mode; then systemctl stop palpanel.service palpanel-sav-cli.service palpanel-palcalc.service; else portable_stop; fi
    ;;
  restart)
    if system_mode; then systemctl restart palpanel-sav-cli.service palpanel-palcalc.service palpanel.service; else portable_stop && portable_start; fi
    ;;
  status)
    if system_mode; then systemctl status palpanel.service palpanel-sav-cli.service palpanel-palcalc.service --no-pager; else portable_status; fi
    ;;
  logs) show_logs "$@" ;;
  config) show_config "$@" ;;
  steam-login) steam_login "$@" ;;
  install) install_system "$@" ;;
  uninstall) uninstall_system "$@" ;;
  -h|--help|help) usage ;;
  *) usage >&2; exit 64 ;;
esac
